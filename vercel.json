{
  "buildCommand": "echo ok",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/public/$1.html"
    },
    {
      "src": "/app",
      "dest": "/public/index.html"
    },
    {
      "src": "/pricing",
      "dest": "/public/pricing.html"
    },
    {
      "src": "/success",
      "dest": "/public/success.html"
    },
    {
      "src": "/auth",
      "dest": "/public/auth-advanced.html"
    },
    {
      "src": "/connectors",
      "dest": "/public/connectors.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}