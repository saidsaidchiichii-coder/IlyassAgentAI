{
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/video.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/agent",
      "destination": "/agent.html"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    }
  ],
  "buildCommand": ""
}