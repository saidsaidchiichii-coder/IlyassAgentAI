{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html",  "use": "@vercel/static" },
    { "src": "auth.html",   "use": "@vercel/static" },
    { "src": "style.css",   "use": "@vercel/static" },
    { "src": "ControleAi.js", "use": "@vercel/static" },
    { "src": "firebase.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",   "dest": "/api/$1" },
    { "src": "/auth",       "dest": "/auth.html" },
    { "src": "/(.*\.(css|js|html|ico|png|jpg|svg))", "dest": "/$1" },
    { "src": "/",           "dest": "/index.html" }
  ]
}
