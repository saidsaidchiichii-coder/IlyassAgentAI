{
  "buildCommand": "echo 'IlyassAI build OK'",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/agent.js": {
      "maxDuration": 60
    },
    "api/image.js": {
      "maxDuration": 60
    },
    "api/video.js": {
      "maxDuration": 60
    },
    "api/create-checkout.js": {
      "maxDuration": 30
    },
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/subscription.js": {
      "maxDuration": 30
    },
    "api/tools.js": {
      "maxDuration": 30
    },
    "api/utilities.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/auth",
      "destination": "/auth-advanced.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/success",
      "destination": "/success.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/connectors",
      "destination": "/connectors.html"
    },
    {
      "source": "/api/subscription-status",
      "destination": "/api/subscription-status"
    },
    {
      "source": "/api/cancel-subscription",
      "destination": "/api/cancel-subscription"
    },
    {
      "source": "/api/billing-portal",
      "destination": "/api/billing-portal"
    },
    {
      "source": "/api/search",
      "destination": "/api/search"
    },
    {
      "source": "/api/moderate",
      "destination": "/api/moderate"
    },
    {
      "source": "/api/parse",
      "destination": "/api/parse"
    },
    {
      "source": "/api/video-status",
      "destination": "/api/video-status"
    },
    {
      "source": "/api/generate-video",
      "destination": "/api/generate-video"
    },
    {
      "source": "/api/memory",
      "destination": "/api/memory"
    },
    {
      "source": "/api/discover",
      "destination": "/api/discover"
    },
    {
      "source": "/api/transcribe",
      "destination": "/api/transcribe"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, x-api-key"
        }
      ]
    }
  ]
}